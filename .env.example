# Server
PORT=3001
APP_ENV=development

# Database
DB_PATH=./server/db/reel_queue.sqlite

# File Storage
UPLOAD_DIR=./server/uploads
THUMBNAIL_DIR=./server/thumbnails
MAX_FILE_SIZE_MB=500

# n8n Security
N8N_WEBHOOK_SECRET=change_me_before_production

# CORS
CORS_ORIGIN=http://localhost:5173

# Platform Dispatcher
PLATFORM_DISPATCH_TIMEOUT_SECONDS=60
